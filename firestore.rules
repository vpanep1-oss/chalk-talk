rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user has access to team
    function hasTeamAccess(teamCode) {
      return request.auth != null || teamCode != null;
    }

    // Teams collection
    match /teams/{teamCode} {
      // Allow read/write if team code is provided
      // In test mode, all operations are allowed
      allow read, write: if true;

      // Custom plans sub-collection
      match /customPlans/{planId} {
        allow read, write: if true;
      }

      // Notes sub-collection
      match /notes/{noteId} {
        allow read, write: if true;
      }

      // Practice history sub-collection
      match /practiceHistory/{sessionId} {
        allow read, write: if true;
      }

      // Drill ratings sub-collection
      match /drillRatings/{ratingId} {
        allow read, write: if true;
      }
    }
  }
}
